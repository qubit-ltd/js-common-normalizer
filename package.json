{
  "name": "@qubit-ltd/common-normalizer",
  "version": "1.8.6",
  "description": "A JavaScript ES6 library for common fields normalizers",
  "author": "Haixing Hu (starfish.hu@gmail.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Haixing-Hu/js-common-normalizer.git"
  },
  "bugs": {
    "url": "https://github.com/Haixing-Hu/js-common-normalizer/issues"
  },
  "homepage": "https://github.com/Haixing-Hu/js-common-normalizer",
  "keywords": [
    "JavaScript",
    "normalizer"
  ],
  "main": "dist/common-normalizer.min.cjs",
  "module": "dist/common-normalizer.min.mjs",
  "exports": {
    ".": {
      "require": "./dist/common-normalizer.min.cjs",
      "import": "./dist/common-normalizer.min.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "doc/**/*",
    "LICENSE",
    "README.md",
    "README.zh_CN.md"
  ],
  "scripts": {
    "clean": "rm -rvf dist doc",
    "build": "cross-env NODE_ENV=production rollup -c rollup.config.mjs",
    "build:dev": "cross-env NODE_ENV=development rollup -c rollup.config.mjs",
    "build:all": "npm run clean && npm run doc && npm run build:dev && npm run build",
    "test": "jest",
    "lint": "eslint ./src ./test",
    "doc": "jsdoc -c jsdoc.json",
    "es5": "check-es-version -e 5 -s true",
    "deploy": "npm run lint && npm run test && npm run build:all && npm publish --registry='https://registry.npmjs.org/' --access public"
  },
  "peerDependencies": {
    "@babel/runtime": "^7.28.5",
    "@qubit-ltd/common-util": "^5.4.7",
    "@qubit-ltd/json": "^1.2.4",
    "dayjs": "^1.11.18"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/runtime": "^7.28.5",
    "@jest/core": "^30.1.3",
    "@qubit-ltd/common-util": "^5.4.9",
    "@qubit-ltd/eslint-config": "^2.0.1",
    "@qubit-ltd/jsdoc-theme": "^1.5.2",
    "@qubit-ltd/json": "^1.2.6",
    "@qubit-ltd/rollup-builder": "^1.8.14",
    "@qubit-ltd/type-detect": "^2.2.8",
    "@qubit-ltd/typeinfo": "^3.3.9",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-jest": "^29.7.0",
    "check-es-version": "^1.5.1",
    "core-js": "^3.45.1",
    "cross-env": "^10.0.0",
    "dayjs": "^1.11.18",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-jsdom-global": "^4.0.0",
    "jest-extended": "^6.0.0",
    "jsdoc": "^4.0.4",
    "rollup": "^4.59.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.2",
    "vue-eslint-parser": "^10.2.0"
  },
  "packageManager": "yarn@4.5.0"
}
